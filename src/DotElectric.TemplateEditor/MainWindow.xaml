<Window x:Class="DotElectric.TemplateEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:DotElectric.TemplateEditor"
        xmlns:converters="clr-namespace:DotElectric.TemplateEditor.Converters"
        xmlns:vm="clr-namespace:DotElectric.TemplateEditor.ViewModels"
        xmlns:views="clr-namespace:DotElectric.TemplateEditor.Views"
        xmlns:behaviors="clr-namespace:DotElectric.TemplateEditor.Behaviors"
        mc:Ignorable="d"
         PreviewKeyDown="Window_PreviewKeyDown"
         Title="DotElectric — Редактор шаблонов"
         Height="768" Width="1280"
         WindowState="Maximized"
        Background="{DynamicResource WindowBackgroundBrush}"
        TextElement.Foreground="{DynamicResource TextPrimaryBrush}"
        TextElement.FontFamily="Segoe UI, Tahoma, Geneva, Verdana, sans-serif"
        TextElement.FontSize="13">

    <!-- Горячие клавиши уровня окна -->
    <Window.InputBindings>
        <!-- Файл -->
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewTabWithLastFormatCommand}"/>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenFileCommand}"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="F12" Command="{Binding SaveAsCommand}"/>
        <KeyBinding Key="P" Modifiers="Control" Command="{Binding PrintCommand}"/>
        <KeyBinding Key="P" Modifiers="Control+Shift" Command="{Binding PreviewPrintCommand}"/>
        
        <!-- Правка -->
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding SelectedTab.UndoCommand}"/>
        <KeyBinding Key="Y" Modifiers="Control" Command="{Binding SelectedTab.RedoCommand}"/>
        <KeyBinding Key="C" Modifiers="Control" Command="{Binding SelectedTab.CopySelectedCommand}"/>
        <KeyBinding Key="V" Modifiers="Control" Command="{Binding SelectedTab.PasteFromClipboardCommand}"/>
        <KeyBinding Key="X" Modifiers="Control" Command="{Binding SelectedTab.CutSelectedCommand}"/>
        <KeyBinding Key="A" Modifiers="Control" Command="{Binding SelectedTab.SelectAllObjectsCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding SelectedTab.DeleteSelectedObjectsCommand}"/>
        
        <!-- Вид -->
        <KeyBinding Key="F7" Command="{Binding SelectedTab.ToggleGridCommand}"/>
        <KeyBinding Key="F8" Command="{Binding SelectedTab.ToggleSnapCommand}"/>
        <KeyBinding Key="F9" Command="{Binding ToggleThemeCommand}"/>
        <KeyBinding Key="D0" Modifiers="Control" Command="{Binding SelectedTab.FitToScreenCommand}" CommandParameter="800,600"/>
        <KeyBinding Key="OemPlus" Modifiers="Control" Command="{Binding SelectedTab.ZoomInCommand}"/>
        <KeyBinding Key="OemMinus" Modifiers="Control" Command="{Binding SelectedTab.ZoomOutCommand}"/>
        
        <!-- Nudge (стрелки) -->
        <KeyBinding Key="Up" Command="{Binding SelectedTab.NudgeUpCommand}"/>
        <KeyBinding Key="Down" Command="{Binding SelectedTab.NudgeDownCommand}"/>
        <KeyBinding Key="Left" Command="{Binding SelectedTab.NudgeLeftCommand}"/>
        <KeyBinding Key="Right" Command="{Binding SelectedTab.NudgeRightCommand}"/>
        <!-- BigNudge (Shift+стрелки) -->
        <KeyBinding Key="Up" Modifiers="Shift" Command="{Binding SelectedTab.BigNudgeUpCommand}"/>
        <KeyBinding Key="Down" Modifiers="Shift" Command="{Binding SelectedTab.BigNudgeDownCommand}"/>
        <KeyBinding Key="Left" Modifiers="Shift" Command="{Binding SelectedTab.BigNudgeLeftCommand}"/>
        <KeyBinding Key="Right" Modifiers="Shift" Command="{Binding SelectedTab.BigNudgeRightCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <!-- DataTemplate для EditorViewModel → EditorCanvas -->
        <DataTemplate DataType="{x:Type vm:EditorViewModel}">
            <views:EditorCanvas />
        </DataTemplate>
        <!-- Конвертер шага сетки -->
        <converters:GridStepToStringConverter x:Key="GridStepToStringConverter"/>
    </Window.Resources>

    <Grid>
        <!-- Row Definitions -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>     <!-- Menu -->
            <RowDefinition Height="Auto"/>     <!-- ToolBar -->
            <RowDefinition Height="*"/>        <!-- Основная область -->
            <RowDefinition Height="Auto"/>     <!-- StatusBar -->
        </Grid.RowDefinitions>

        <!-- Column Definitions -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" MinWidth="150" MaxWidth="400"/>  <!-- Левая панель -->
            <ColumnDefinition Width="Auto"/>     <!-- GridSplitter -->
            <ColumnDefinition Width="*"/>        <!-- Центр (TabControl) -->
            <ColumnDefinition Width="Auto"/>     <!-- GridSplitter -->
            <ColumnDefinition Width="250" MinWidth="200" MaxWidth="500"/> <!-- Правая панель -->
        </Grid.ColumnDefinitions>

        <!-- ==================== MENU ==================== -->
        <Menu Grid.Row="0" Grid.ColumnSpan="5"
              Background="{DynamicResource MenuBackgroundBrush}"
              Foreground="{DynamicResource TextPrimaryBrush}"
              FontSize="14">
            <MenuItem Header="_Файл">
                <!-- Подменю "Новый шаблон" с выбором форматов -->
                <MenuItem Header="_Новый шаблон">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="FilePlusOutline" Width="16" Height="16"/>
                    </MenuItem.Icon>
                    <!-- A0 -->
                    <MenuItem Header="A0">
                        <MenuItem Header="Альбомная (1189×841)" Command="{Binding NewTabCommand}" CommandParameter="A0L"/>
                        <MenuItem Header="Книжная (841×1189)" Command="{Binding NewTabCommand}" CommandParameter="A0P"/>
                    </MenuItem>
                    <!-- A1 -->
                    <MenuItem Header="A1">
                        <MenuItem Header="Альбомная (841×594)" Command="{Binding NewTabCommand}" CommandParameter="A1L"/>
                        <MenuItem Header="Книжная (594×841)" Command="{Binding NewTabCommand}" CommandParameter="A1P"/>
                    </MenuItem>
                    <!-- A2 -->
                    <MenuItem Header="A2">
                        <MenuItem Header="Альбомная (594×420)" Command="{Binding NewTabCommand}" CommandParameter="A2L"/>
                        <MenuItem Header="Книжная (420×594)" Command="{Binding NewTabCommand}" CommandParameter="A2P"/>
                    </MenuItem>
                    <!-- A3 -->
                    <MenuItem Header="A3">
                        <MenuItem Header="Альбомная (420×297)" Command="{Binding NewTabCommand}" CommandParameter="A3L"/>
                        <MenuItem Header="Книжная (297×420)" Command="{Binding NewTabCommand}" CommandParameter="A3P"/>
                    </MenuItem>
                    <!-- A4 -->
                    <MenuItem Header="A4">
                        <MenuItem Header="Книжная (210×297)" Command="{Binding NewTabCommand}" CommandParameter="A4P"/>
                        <MenuItem Header="Альбомная (297×210)" Command="{Binding NewTabCommand}" CommandParameter="A4L"/>
                    </MenuItem>
                    <Separator/>
                    <!-- Half-форматы -->
                    <MenuItem Header="A4×2">
                        <MenuItem Header="Книжная (210×594)" Command="{Binding NewTabCommand}" CommandParameter="A4×2P"/>
                        <MenuItem Header="Альбомная (594×210)" Command="{Binding NewTabCommand}" CommandParameter="A4×2L"/>
                    </MenuItem>
                    <MenuItem Header="A3×2">
                        <MenuItem Header="Книжная (297×840)" Command="{Binding NewTabCommand}" CommandParameter="A3×2P"/>
                        <MenuItem Header="Альбомная (840×297)" Command="{Binding NewTabCommand}" CommandParameter="A3×2L"/>
                    </MenuItem>
                    <MenuItem Header="A2×2">
                        <MenuItem Header="Книжная (420×1188)" Command="{Binding NewTabCommand}" CommandParameter="A2×2P"/>
                        <MenuItem Header="Альбомная (1188×420)" Command="{Binding NewTabCommand}" CommandParameter="A2×2L"/>
                    </MenuItem>
                    <MenuItem Header="A1×2">
                        <MenuItem Header="Книжная (594×1682)" Command="{Binding NewTabCommand}" CommandParameter="A1×2P"/>
                        <MenuItem Header="Альбомная (1682×594)" Command="{Binding NewTabCommand}" CommandParameter="A1×2L"/>
                    </MenuItem>
                    <MenuItem Header="A0×2">
                        <MenuItem Header="Книжная (841×2378)" Command="{Binding NewTabCommand}" CommandParameter="A0×2P"/>
                        <MenuItem Header="Альбомная (2378×841)" Command="{Binding NewTabCommand}" CommandParameter="A0×2L"/>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Пользовательский..." Command="{Binding NewCustomTabCommand}"/>
                </MenuItem>
                <MenuItem Header="_Открыть..." Command="{Binding OpenFileCommand}"
                          InputGestureText="Ctrl+O">
                    <MenuItem.Icon><materialDesign:PackIcon Kind="FolderOpenOutline" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Сохранить" Command="{Binding SaveCommand}"
                          InputGestureText="Ctrl+S">
                    <MenuItem.Icon><materialDesign:PackIcon Kind="ContentSaveOutline" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Сохранить _как..." Command="{Binding SaveAsCommand}" InputGestureText="F12"/>
                <MenuItem Header="Сохранить _все" Command="{Binding SaveAllCommand}"/>
                <Separator/>
                <MenuItem Header="_Настройки..." Command="{Binding OpenSettingsCommand}">
                    <MenuItem.Icon><materialDesign:PackIcon Kind="CogOutline" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Печать..." Command="{Binding PrintCommand}"
                          InputGestureText="Ctrl+P">
                    <MenuItem.Icon><materialDesign:PackIcon Kind="Printer" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Предпросмотр печати" Command="{Binding PreviewPrintCommand}"
                          InputGestureText="Ctrl+Shift+P">
                    <MenuItem.Icon><materialDesign:PackIcon Kind="FileEyeOutline" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Вы_ход" Command="{Binding ExitCommand}" InputGestureText="Alt+F4"/>
            </MenuItem>
            <MenuItem Header="_Правка">
                <MenuItem Header="_Отменить" Command="{Binding SelectedTab.UndoCommand}"
                          InputGestureText="Ctrl+Z">
                    <MenuItem.Icon><materialDesign:PackIcon Kind="Undo" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Повторить" Command="{Binding SelectedTab.RedoCommand}"
                          InputGestureText="Ctrl+Y">
                    <MenuItem.Icon><materialDesign:PackIcon Kind="Redo" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Вы_резать" Command="{Binding SelectedTab.CutSelectedCommand}"
                          InputGestureText="Ctrl+X">
                    <MenuItem.Icon><materialDesign:PackIcon Kind="ContentCut" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Копировать" Command="{Binding SelectedTab.CopySelectedCommand}"
                          InputGestureText="Ctrl+C">
                    <MenuItem.Icon><materialDesign:PackIcon Kind="ContentCopy" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Вставить" Command="{Binding SelectedTab.PasteFromClipboardCommand}"
                          InputGestureText="Ctrl+V">
                    <MenuItem.Icon><materialDesign:PackIcon Kind="ContentPaste" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Удалить" Command="{Binding SelectedTab.DeleteSelectedObjectsCommand}"
                          InputGestureText="Delete">
                    <MenuItem.Icon><materialDesign:PackIcon Kind="DeleteOutline" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Выделить _все" Command="{Binding SelectedTab.SelectAllObjectsCommand}"
                          InputGestureText="Ctrl+A"/>
            </MenuItem>
            <MenuItem Header="_Вид">
                <MenuItem Header="_Сетка" Command="{Binding SelectedTab.ToggleGridCommand}"
                          InputGestureText="F7">
                    <MenuItem.Icon><materialDesign:PackIcon Kind="Grid" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Привязка к сетке" Command="{Binding SelectedTab.ToggleSnapCommand}"
                          InputGestureText="F8">
                    <MenuItem.Icon><materialDesign:PackIcon Kind="Magnet" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Увеличить" Command="{Binding SelectedTab.ZoomInCommand}"
                          InputGestureText="Ctrl++">
                    <MenuItem.Icon><materialDesign:PackIcon Kind="MagnifyPlusOutline" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Уменьшить" Command="{Binding SelectedTab.ZoomOutCommand}"
                          InputGestureText="Ctrl+-">
                    <MenuItem.Icon><materialDesign:PackIcon Kind="MagnifyMinusOutline" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Вписать в экран"
                          Command="{Binding SelectedTab.FitToScreenCommand}"
                          InputGestureText="Ctrl+0">
                    <MenuItem.Icon><materialDesign:PackIcon Kind="ArrowExpandAll" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Переключить тему" Command="{Binding ToggleThemeCommand}"
                          InputGestureText="F9">
                    <MenuItem.Icon><materialDesign:PackIcon Kind="ThemeLightDark" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Вставка">
                <MenuItem Header="_Линия" Command="{Binding SelectedTab.SetActiveToolCommand}"
                          CommandParameter="Line" InputGestureText="L">
                    <MenuItem.Icon><materialDesign:PackIcon Kind="Minus" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Прямоугольник" Command="{Binding SelectedTab.SetActiveToolCommand}"
                          CommandParameter="Rectangle" InputGestureText="R">
                    <MenuItem.Icon><materialDesign:PackIcon Kind="SquareOutline" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Текст" Command="{Binding SelectedTab.SetActiveToolCommand}"
                          CommandParameter="Text" InputGestureText="T">
                    <MenuItem.Icon><materialDesign:PackIcon Kind="FormatText" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Инструменты">
                <MenuItem Header="_Выделение" Command="{Binding SelectedTab.SetActiveToolCommand}"
                          CommandParameter="Select" InputGestureText="V">
                    <MenuItem.Icon><materialDesign:PackIcon Kind="CursorDefaultClickOutline" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Настройки"/>
            </MenuItem>
            <MenuItem Header="_Справка">
                <MenuItem Header="_Документация">
                    <MenuItem.Icon><materialDesign:PackIcon Kind="HelpCircleOutline" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_О программе">
                    <MenuItem.Icon><materialDesign:PackIcon Kind="InformationOutline" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- ==================== TOOLBAR ==================== -->
        <Border Grid.Row="1" Grid.ColumnSpan="5"
                Background="{DynamicResource ToolBarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <WrapPanel Margin="4,2" Orientation="Horizontal">
                <!-- Файл -->
                <Button Style="{DynamicResource ToolBarButtonStyle}"
                        Command="{Binding NewTabWithLastFormatCommand}"
                        ToolTip="Новый шаблон (Ctrl+N)">
                    <materialDesign:PackIcon Kind="FilePlusOutline" Width="20" Height="20"/>
                </Button>
                <Button Style="{DynamicResource ToolBarButtonStyle}"
                        Command="{Binding OpenFileCommand}"
                        ToolTip="Открыть (Ctrl+O)">
                    <materialDesign:PackIcon Kind="FolderOpenOutline" Width="20" Height="20"/>
                </Button>
                <Button Style="{DynamicResource ToolBarButtonStyle}"
                        Command="{Binding SaveCommand}"
                        ToolTip="Сохранить (Ctrl+S)">
                    <materialDesign:PackIcon Kind="ContentSaveOutline" Width="20" Height="20"/>
                </Button>

                <!-- Separator -->
                <Separator Style="{StaticResource ToolBarSeparatorStyle}"/>

                <!-- Правка -->
                <Button Style="{DynamicResource ToolBarButtonStyle}"
                        Command="{Binding SelectedTab.UndoCommand}"
                        ToolTip="Отменить (Ctrl+Z)">
                    <materialDesign:PackIcon Kind="Undo" Width="20" Height="20"/>
                </Button>
                <Button Style="{DynamicResource ToolBarButtonStyle}"
                        Command="{Binding SelectedTab.RedoCommand}"
                        ToolTip="Повторить (Ctrl+Y)">
                    <materialDesign:PackIcon Kind="Redo" Width="20" Height="20"/>
                </Button>

                <!-- Separator -->
                <Separator Style="{StaticResource ToolBarSeparatorStyle}"/>

                <!-- Копировать/Вырезать/Вставить/Удалить -->
                <Button Style="{DynamicResource ToolBarButtonStyle}"
                        Command="{Binding SelectedTab.CopySelectedCommand}"
                        ToolTip="Копировать (Ctrl+C)">
                    <materialDesign:PackIcon Kind="ContentCopy" Width="20" Height="20"/>
                </Button>
                <Button Style="{DynamicResource ToolBarButtonStyle}"
                        Command="{Binding SelectedTab.CutSelectedCommand}"
                        ToolTip="Вырезать (Ctrl+X)">
                    <materialDesign:PackIcon Kind="ContentCut" Width="20" Height="20"/>
                </Button>
                <Button Style="{DynamicResource ToolBarButtonStyle}"
                        Command="{Binding SelectedTab.PasteFromClipboardCommand}"
                        ToolTip="Вставить (Ctrl+V)">
                    <materialDesign:PackIcon Kind="ContentPaste" Width="20" Height="20"/>
                </Button>
                <Button Style="{DynamicResource ToolBarButtonStyle}"
                        Command="{Binding SelectedTab.DeleteSelectedObjectsCommand}"
                        ToolTip="Удалить (Delete)">
                    <materialDesign:PackIcon Kind="DeleteOutline" Width="20" Height="20"/>
                </Button>

                <!-- Separator -->
                <Separator Style="{StaticResource ToolBarSeparatorStyle}"/>

                <!-- Масштаб -->
                <Button Style="{DynamicResource ToolBarButtonStyle}"
                        Command="{Binding SelectedTab.ZoomOutCommand}"
                        ToolTip="Уменьшить (Ctrl+-)">
                    <materialDesign:PackIcon Kind="MagnifyMinusOutline" Width="20" Height="20"/>
                </Button>
                <Button Style="{DynamicResource ToolBarButtonStyle}"
                        Command="{Binding SelectedTab.ZoomInCommand}"
                        ToolTip="Увеличить (Ctrl++)">
                    <materialDesign:PackIcon Kind="MagnifyPlusOutline" Width="20" Height="20"/>
                </Button>
                <Button Style="{DynamicResource ToolBarButtonStyle}"
                        Command="{Binding SelectedTab.FitToScreenCommand}"
                        ToolTip="Вписать в экран (Ctrl+0)">
                    <materialDesign:PackIcon Kind="ArrowExpandAll" Width="20" Height="20"/>
                </Button>

                <!-- Separator -->
                <Separator Style="{StaticResource ToolBarSeparatorStyle}"/>

                <!-- Печать -->
                <Button Style="{DynamicResource ToolBarButtonStyle}"
                        Command="{Binding PrintCommand}"
                        ToolTip="Печать (Ctrl+P)">
                    <materialDesign:PackIcon Kind="Printer" Width="20" Height="20"/>
                </Button>

                <!-- Separator -->
                <Separator Style="{StaticResource ToolBarSeparatorStyle}"/>

                <!-- Инструменты рисования -->
                <RadioButton Style="{DynamicResource ToolBarRadioButtonStyle}"
                             IsChecked="{Binding SelectedTab.ToolManager.ActiveTool, Converter={StaticResource EqualToBoolConverter}, ConverterParameter=Select}"
                             Command="{Binding SelectedTab.SetActiveToolCommand}" CommandParameter="Select"
                             GroupName="DrawingTools"
                             ToolTip="Выделение (V)">
                    <materialDesign:PackIcon Kind="CursorDefaultClickOutline" Width="20" Height="20"/>
                </RadioButton>
                <RadioButton Style="{DynamicResource ToolBarRadioButtonStyle}"
                             IsChecked="{Binding SelectedTab.ToolManager.ActiveTool, Converter={StaticResource EqualToBoolConverter}, ConverterParameter=Line}"
                             Command="{Binding SelectedTab.SetActiveToolCommand}" CommandParameter="Line"
                             GroupName="DrawingTools"
                             ToolTip="Линия (L)">
                    <materialDesign:PackIcon Kind="Minus" Width="20" Height="20"/>
                </RadioButton>
                <RadioButton Style="{DynamicResource ToolBarRadioButtonStyle}"
                             IsChecked="{Binding SelectedTab.ToolManager.ActiveTool, Converter={StaticResource EqualToBoolConverter}, ConverterParameter=Rectangle}"
                             Command="{Binding SelectedTab.SetActiveToolCommand}" CommandParameter="Rectangle"
                             GroupName="DrawingTools"
                             ToolTip="Прямоугольник (R)">
                    <materialDesign:PackIcon Kind="SquareOutline" Width="20" Height="20"/>
                </RadioButton>
                <RadioButton Style="{DynamicResource ToolBarRadioButtonStyle}"
                             IsChecked="{Binding SelectedTab.ToolManager.ActiveTool, Converter={StaticResource EqualToBoolConverter}, ConverterParameter=Text}"
                             Command="{Binding SelectedTab.SetActiveToolCommand}" CommandParameter="Text"
                             GroupName="DrawingTools"
                             ToolTip="Текст (T)">
                    <materialDesign:PackIcon Kind="FormatText" Width="20" Height="20"/>
                </RadioButton>

                <!-- Separator -->
                <Separator Style="{StaticResource ToolBarSeparatorStyle}"/>

                <!-- Сетка / Привязка -->
                <ToggleButton Style="{DynamicResource ToolBarToggleButtonStyle}"
                              IsChecked="{Binding SelectedTab.GridManager.IsGridEnabled}"
                              ToolTip="Сетка (F7)">
                    <materialDesign:PackIcon Kind="Grid" Width="20" Height="20"/>
                </ToggleButton>
                <!-- Шаг сетки -->
                <ComboBox Width="75" Height="30" Margin="4,0"
                          Text="{Binding SelectedTab.StatusBarManager.GridStepMm, Converter={StaticResource GridStepToStringConverter}}"
                          ToolTip="Шаг сетки"
                          VerticalAlignment="Center"
                          Background="{DynamicResource PanelBackgroundBrush}"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          IsEditable="False">
                    <ComboBoxItem Content="1 мм"/>
                    <ComboBoxItem Content="2 мм"/>
                    <ComboBoxItem Content="5 мм"/>
                    <ComboBoxItem Content="10 мм"/>
                </ComboBox>
                <ToggleButton Style="{DynamicResource ToolBarToggleButtonStyle}"
                              IsChecked="{Binding SelectedTab.GridManager.IsSnapEnabled}"
                              ToolTip="Привязка (F8)">
                    <materialDesign:PackIcon Kind="Magnet" Width="20" Height="20"/>
                </ToggleButton>

                <!-- Separator -->
                <Separator Style="{StaticResource ToolBarSeparatorStyle}"/>

                <!-- Тема -->
                <Button Style="{DynamicResource ToolBarButtonStyle}"
                        Command="{Binding ToggleThemeCommand}"
                        ToolTip="Переключить тему (F9)">
                    <materialDesign:PackIcon Kind="ThemeLightDark" Width="20" Height="20"/>
                </Button>

                <!-- Separator -->
                <Separator Style="{StaticResource ToolBarSeparatorStyle}"/>

                <!-- ComboBox масштаба -->
                <ComboBox Width="90" Height="30" Margin="4,0"
                          Text="{Binding SelectedTab.ZoomPanManager.ZoomPercent, Mode=OneWay, StringFormat={}{0}%}"
                          behaviors:ZoomComboBoxBehavior.Editor="{Binding SelectedTab}"
                          IsEditable="True"
                          VerticalAlignment="Center"
                          Background="{DynamicResource PanelBackgroundBrush}"
                          Foreground="{DynamicResource TextPrimaryBrush}">
                    <ComboBoxItem Content="10%"/>
                    <ComboBoxItem Content="25%"/>
                    <ComboBoxItem Content="50%"/>
                    <ComboBoxItem Content="75%"/>
                    <ComboBoxItem Content="100%"/>
                    <ComboBoxItem Content="150%"/>
                    <ComboBoxItem Content="200%"/>
                    <ComboBoxItem Content="500%"/>
                </ComboBox>
            </WrapPanel>
        </Border>

        <!-- ==================== ЛЕВАЯ ПАНЕЛЬ ==================== -->
        <Border Grid.Row="2" Grid.Column="0"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel DataContext="{Binding TemplateLibraryVm}">
                <!-- Заголовок: Библиотека шаблонов -->
                <TextBlock Text="БИБЛИОТЕКА ШАБЛОНОВ" FontWeight="SemiBold"
                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="12,12,12,6" DockPanel.Dock="Top"
                           TextOptions.TextFormattingMode="Display"/>

                <!-- Кнопки импорта/удаления -->
                <StackPanel Orientation="Horizontal" Margin="6,0,6,6" DockPanel.Dock="Top">
                    <Button Command="{Binding ImportToLibraryCommand}"
                            Margin="0,0,4,0" Padding="4,2"
                            ToolTip="Добавить шаблон из файла"
                            Background="{DynamicResource ButtonBackgroundBrush}"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderBrush}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FilePlusOutline" Width="14" Height="14" Margin="0,0,4,0"/>
                            <TextBlock Text="Импорт" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RemoveFromLibraryCommand}"
                            Padding="4,2"
                            ToolTip="Удалить выбранный шаблон"
                            Background="{DynamicResource ButtonBackgroundBrush}"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderBrush}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DeleteOutline" Width="14" Height="14" Margin="0,0,4,0"/>
                            <TextBlock Text="Удалить" FontSize="11"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Список шаблонов -->
                <views:TemplateLibraryView Margin="6" VerticalAlignment="Stretch"/>
            </DockPanel>
        </Border>

        <!-- GridSplitter левый -->
        <GridSplitter Grid.Row="2" Grid.Column="1"
                      Width="3" HorizontalAlignment="Center"
                      Background="{DynamicResource BorderBrush}"/>

        <!-- ==================== ЦЕНТР: ЗАГЛУШКА (нет вкладок) ==================== -->
        <StackPanel Grid.Row="2" Grid.Column="2"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding OpenedTabs.Count, Converter={StaticResource ZeroToVisibilityConverter}}">
            <materialDesign:PackIcon Kind="FileDocumentEditOutline"
                                     Width="64" Height="64"
                                     Foreground="{DynamicResource TextDisabledBrush}"
                                     HorizontalAlignment="Center"
                                     Margin="0,0,0,16"/>
            <TextBlock Text="Создайте новый шаблон"
                       FontSize="18" Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="Ctrl+N — новый  |  Ctrl+O — открыть"
                       FontSize="13" Foreground="{DynamicResource TextDisabledBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- ==================== ЦЕНТР: TABCONTROL (есть вкладки) ==================== -->
        <Border Grid.Row="2" Grid.Column="2"
                Background="{DynamicResource TabControlBackgroundBrush}"
                Visibility="{Binding OpenedTabs.Count, Converter={StaticResource NonZeroToVisibilityConverter}}">
            <TabControl x:Name="MainTabControl"
                        ItemsSource="{Binding OpenedTabs}"
                        SelectedItem="{Binding SelectedTab}"
                        Background="Transparent"
                        BorderThickness="0"
                        behaviors:TabItemMiddleClickBehavior.EnableMiddleClickToClose="True">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem" BasedOn="{StaticResource {x:Type TabItem}}">
                        <Setter Property="Header" Value="{Binding DirtyStateManager.DisplayName}"/>
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu>
                                    <MenuItem Header="Закрыть" Command="{Binding CloseTabCommand}"/>
                                    <MenuItem Header="Закрыть другие" Command="{Binding CloseOtherTabsCommand}"/>
                                    <MenuItem Header="Закрыть все" Command="{Binding CloseAllTabsCommand}"/>
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.ItemContainerStyle>
            </TabControl>
        </Border>

        <!-- GridSplitter правый -->
        <GridSplitter Grid.Row="2" Grid.Column="3"
                      Width="3" HorizontalAlignment="Center"
                      Background="{DynamicResource BorderBrush}"/>

        <!-- ==================== ПРАВАЯ ПАНЕЛЬ: СВОЙСТВА ==================== -->
        <Border Grid.Row="2" Grid.Column="4"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1,0,0,0">
            <DockPanel DataContext="{Binding SelectedTab.PropertiesVm}">
                <!-- Заголовок -->
                <TextBlock Text="СВОЙСТВА" FontWeight="SemiBold"
                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="12,12,12,10" DockPanel.Dock="Top"
                           TextOptions.TextFormattingMode="Display"/>

                <!-- Разделитель -->
                <Border DockPanel.Dock="Top" Margin="12,0,12,8"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"/>

                <!-- Контент -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Padding="8,0">
                    <views:PropertiesPanelContent />
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ==================== STATUS BAR ==================== -->
        <StatusBar Grid.Row="3" Grid.ColumnSpan="5"
                   Background="{DynamicResource StatusBarBackgroundBrush}"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   BorderBrush="{DynamicResource BorderBrush}"
                   BorderThickness="0,1,0,0"
                   FontSize="12"
                   DataContext="{Binding SelectedTab}">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>   <!-- Статус -->
                            <ColumnDefinition Width="*"/>      <!-- Spacer -->
                            <ColumnDefinition Width="Auto"/>   <!-- Сетка -->
                            <ColumnDefinition Width="Auto"/>   <!-- Привязка -->
                            <ColumnDefinition Width="Auto"/>   <!-- Формат -->
                            <ColumnDefinition Width="Auto"/>   <!-- Масштаб -->
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <!-- Статус -->
            <StatusBarItem Grid.Column="0" Margin="8,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="CheckCircleOutline" Width="14" Height="14"
                                             Foreground="{DynamicResource SelectionGreenBrush}"
                                             VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding StatusBarManager.StatusMessage}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </StatusBarItem>

            <!-- Сетка (toggle) -->
            <StatusBarItem Grid.Column="2" Margin="4,0">
                <ToggleButton Content="Сетка" FontSize="11"
                              IsChecked="{Binding GridManager.IsGridEnabled}"
                              Foreground="{DynamicResource TextSecondaryBrush}"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="6,2"
                              Cursor="Hand"/>
            </StatusBarItem>

            <!-- Привязка (toggle) -->
            <StatusBarItem Grid.Column="3" Margin="4,0">
                <ToggleButton Content="Привязка" FontSize="11"
                              IsChecked="{Binding GridManager.IsSnapEnabled}"
                              Foreground="{DynamicResource TextSecondaryBrush}"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="6,2"
                              Cursor="Hand"/>
            </StatusBarItem>

            <!-- Формат листа -->
            <StatusBarItem Grid.Column="4" Margin="4,0">
                <TextBlock Text="{Binding StatusBarManager.SheetFormat}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Cursor="Hand"/>
            </StatusBarItem>

            <!-- Масштаб -->
            <StatusBarItem Grid.Column="5" Margin="4,0">
                <TextBlock Text="{Binding ZoomPanManager.ZoomPercent, StringFormat={}{0}%}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Cursor="Hand"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
