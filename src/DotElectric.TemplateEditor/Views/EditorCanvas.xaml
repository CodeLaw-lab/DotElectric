<UserControl x:Class="DotElectric.TemplateEditor.Views.EditorCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:DotElectric.TemplateEditor.Views"
             xmlns:models="clr-namespace:DotElectric.TemplateEditor.Models.Objects"
             xmlns:coreModels="clr-namespace:DotElectric.TemplateEditor.Models"
             xmlns:behaviors="clr-namespace:DotElectric.TemplateEditor.Behaviors"
             xmlns:converters="clr-namespace:DotElectric.TemplateEditor.Converters"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignWidth="800" d:DesignHeight="600"
             Focusable="True">

    <!-- Горячие клавиши (inline editing) -->
    <UserControl.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding CommitInlineEditingCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding CancelInlineEditingCommand}"/>
    </UserControl.InputBindings>

    <!-- Контекстное меню Canvas -->
    <UserControl.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Вырезать" Command="{Binding CutSelectedCommand}" InputGestureText="Ctrl+X">
                <MenuItem.Icon><materialDesign:PackIcon Kind="ContentCut" Width="16" Height="16"/></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Копировать" Command="{Binding CopySelectedCommand}" InputGestureText="Ctrl+C">
                <MenuItem.Icon><materialDesign:PackIcon Kind="ContentCopy" Width="16" Height="16"/></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Вставить" Command="{Binding PasteFromClipboardCommand}" InputGestureText="Ctrl+V">
                <MenuItem.Icon><materialDesign:PackIcon Kind="ContentPaste" Width="16" Height="16"/></MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Удалить" Command="{Binding DeleteSelectedObjectsCommand}" InputGestureText="Delete">
                <MenuItem.Icon><materialDesign:PackIcon Kind="DeleteOutline" Width="16" Height="16"/></MenuItem.Icon>
            </MenuItem>
            <Separator/>
        </ContextMenu>
    </UserControl.ContextMenu>

    <UserControl.Resources>
        <!-- Конвертеры -->
        <converters:ModelXToCanvasLeftConverter x:Key="ModelXToCanvasLeftConverter"/>
        <converters:ModelYToCanvasTopConverter x:Key="ModelYToCanvasTopConverter"/>
        <converters:MicronsToPixelConverter x:Key="MicronsToPixelConverter"/>
        <converters:LineTypeToDashArrayConverter x:Key="LineTypeToDashArrayConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:NotNullToVisibilityConverter x:Key="NotNullToVisibility"/>
        <converters:IsHoveredConverter x:Key="IsHoveredConverter"/>
        <converters:IsObjectSelectedConverter x:Key="IsObjectSelectedConverter"/>
        <converters:NonZeroToVisibilityConverter x:Key="NonZeroToVisibilityConverter"/>
        <converters:HexToBrushConverter x:Key="HexToBrushConverter"/>
        <converters:BoolToTextWrappingConverter x:Key="BoolToTextWrappingConverter"/>
        <converters:StringToTextAlignmentConverter x:Key="StringToTextAlignmentConverter"/>

        <Style x:Key="WorkspaceScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#888"/>
        </Style>

        <!-- Шаблон линии -->
        <DataTemplate DataType="{x:Type models:Line}">
            <Line>
                <Line.Style>
                    <Style TargetType="Line">
                        <Setter Property="Stroke" Value="{Binding StrokeColor, Converter={StaticResource HexToBrushConverter}}"/>
                        <Setter Property="StrokeThickness">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource MicronsToPixelConverter}">
                                    <Binding Path="StrokeThicknessMicrons"/>
                                    <Binding Path="DataContext.ZoomPanManager.Zoom" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="X1">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource LineLocalConverter}" ConverterParameter="X1">
                                    <Binding Path="StartMicronsX"/>
                                    <Binding Path="EndMicronsX"/>
                                    <Binding Path="DataContext.ZoomPanManager.Zoom" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Y1">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource LineLocalConverter}" ConverterParameter="Y1">
                                    <Binding Path="StartMicronsY"/>
                                    <Binding Path="EndMicronsY"/>
                                    <Binding Path="DataContext.Template.Sheet.HeightMm" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                    <Binding Path="DataContext.ZoomPanManager.Zoom" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="X2">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource LineLocalConverter}" ConverterParameter="X2">
                                    <Binding Path="StartMicronsX"/>
                                    <Binding Path="EndMicronsX"/>
                                    <Binding Path="DataContext.ZoomPanManager.Zoom" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Y2">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource LineLocalConverter}" ConverterParameter="Y2">
                                    <Binding Path="StartMicronsY"/>
                                    <Binding Path="EndMicronsY"/>
                                    <Binding Path="DataContext.Template.Sheet.HeightMm" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                    <Binding Path="DataContext.ZoomPanManager.Zoom" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="StrokeDashArray" Value="{Binding LineType, Converter={StaticResource LineTypeToDashArrayConverter}}"/>
                        <Style.Triggers>
                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <MultiBinding Converter="{StaticResource IsHoveredConverter}">
                                        <Binding/>
                                        <Binding Path="DataContext.HoveredObject" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                    </MultiBinding>
                                </DataTrigger.Binding>
                                <Setter Property="StrokeThickness" Value="2.5"/>
                                <Setter Property="Stroke" Value="#333"/>
                            </DataTrigger>
                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <MultiBinding Converter="{StaticResource IsObjectSelectedConverter}">
                                        <Binding/>
                                        <Binding Path="DataContext.SelectionManager.SelectedObjects" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                        <Binding Path="DataContext.SelectionVersion" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                    </MultiBinding>
                                </DataTrigger.Binding>
                                <Setter Property="StrokeThickness" Value="2"/>
                                <Setter Property="Stroke" Value="#0078D4"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Line.Style>
            </Line>
        </DataTemplate>

        <!-- Шаблон прямоугольника -->
        <DataTemplate DataType="{x:Type models:Rectangle}">
            <Rectangle>
                <Rectangle.Width>
                    <MultiBinding Converter="{StaticResource MicronsToPixelConverter}">
                        <Binding Path="WidthMicrons"/>
                        <Binding Path="DataContext.ZoomPanManager.Zoom" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                    </MultiBinding>
                </Rectangle.Width>
                <Rectangle.Height>
                    <MultiBinding Converter="{StaticResource MicronsToPixelConverter}">
                        <Binding Path="HeightMicrons"/>
                        <Binding Path="DataContext.ZoomPanManager.Zoom" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                    </MultiBinding>
                </Rectangle.Height>
                <Rectangle.Style>
                    <Style TargetType="Rectangle">
                        <Setter Property="Stroke" Value="{Binding StrokeColor, Converter={StaticResource HexToBrushConverter}}"/>
                        <Setter Property="Fill" Value="{Binding FillColor, Converter={StaticResource HexToBrushConverter}}"/>
                        <Setter Property="StrokeThickness">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource MicronsToPixelConverter}">
                                    <Binding Path="StrokeThicknessMicrons"/>
                                    <Binding Path="DataContext.ZoomPanManager.Zoom" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="StrokeDashArray" Value="{Binding LineType, Converter={StaticResource LineTypeToDashArrayConverter}}"/>
                        <Style.Triggers>
                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <MultiBinding Converter="{StaticResource IsObjectSelectedConverter}">
                                        <Binding/>
                                        <Binding Path="DataContext.SelectionManager.SelectedObjects" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                        <Binding Path="DataContext.SelectionVersion" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                    </MultiBinding>
                                </DataTrigger.Binding>
                                <Setter Property="StrokeThickness" Value="2"/>
                                <Setter Property="Stroke" Value="#0078D4"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Rectangle.Style>
            </Rectangle>
        </DataTemplate>

        <!-- Шаблон текста -->
        <DataTemplate DataType="{x:Type models:Text}">
            <Grid>
                <TextBlock FontFamily="{Binding FontName, Converter={StaticResource FontNameToFamilyConverter}}"
                           TextWrapping="{Binding TextWrapping, Converter={StaticResource BoolToTextWrappingConverter}}"
                           TextAlignment="{Binding TextAlignment, Converter={StaticResource StringToTextAlignmentConverter}}"
                           >
                    <TextBlock.FontSize>
                        <MultiBinding Converter="{StaticResource MicronsToPixelConverter}">
                            <Binding Path="FontSizeMicrons"/>
                            <Binding Path="DataContext.ZoomPanManager.Zoom" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                        </MultiBinding>
                    </TextBlock.FontSize>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{Binding Foreground, Converter={StaticResource HexToBrushConverter}}"/>
                            <Style.Triggers>
                                <DataTrigger Value="True">
                                    <DataTrigger.Binding>
                                        <MultiBinding Converter="{StaticResource IsObjectSelectedConverter}">
                                            <Binding/>
                                            <Binding Path="DataContext.SelectionManager.SelectedObjects" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                            <Binding Path="DataContext.SelectionVersion" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                        </MultiBinding>
                                    </DataTrigger.Binding>
                                    <Setter Property="Foreground" Value="#0078D4"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                    <TextBlock.Text>
                        <Binding Path="Content"/>
                    </TextBlock.Text>
                    <TextBlock.LayoutTransform>
                        <RotateTransform>
                            <RotateTransform.Angle>
                                <Binding Path="RotationAngle"/>
                            </RotateTransform.Angle>
                        </RotateTransform>
                    </TextBlock.LayoutTransform>
                </TextBlock>
            </Grid>
        </DataTemplate>

    </UserControl.Resources>

    <!-- Фон и область отсечения + скроллбары -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
        </Grid.ColumnDefinitions>

        <!-- Canvas area -->
        <Border x:Name="CanvasBorder" Grid.Row="0" Grid.Column="0" Background="#F0F0F0" ClipToBounds="True"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <!-- Shared grid to layer DrawingCanvas (back) and GridNodesLayer (front) as siblings -->
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Canvas с attached behavior и RenderTransform для панорамирования -->
                <Canvas x:Name="DrawingCanvas"
                        behaviors:EditorCanvasBehavior.Editor="{Binding}"
                        Background="White"
                        ClipToBounds="True"
                        Focusable="True"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Canvas.RenderTransform>
                        <TranslateTransform X="{ Binding ZoomPanManager.CanvasOffsetX}" Y="{ Binding ZoomPanManager.CanvasOffsetY}"/>
                    </Canvas.RenderTransform>

                    <!-- Размер Canvas = размер листа в пикселях -->
                    <Canvas.Width>
                        <MultiBinding Converter="{StaticResource MicronsToPixelConverter}">
                            <Binding Path="Template.Sheet.WidthMicrons"/>
                            <Binding Path="ZoomPanManager.Zoom"/>
                        </MultiBinding>
                    </Canvas.Width>
                    <Canvas.Height>
                        <MultiBinding Converter="{StaticResource MicronsToPixelConverter}">
                            <Binding Path="Template.Sheet.HeightMicrons"/>
                            <Binding Path="ZoomPanManager.Zoom"/>
                        </MultiBinding>
                    </Canvas.Height>

                <!-- Zoom через Width/Height Canvas (НЕ через LayoutTransform — это вызывало двойное масштабирование) -->

            <!-- Объекты шаблона -->
            <ItemsControl ItemsSource="{Binding Template.Objects}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource LeftEdgeMicronsMultiConverter}">
                                    <Binding Path="StartMicronsX"/>    <!-- Line -->
                                    <Binding Path="EndMicronsX"/>      <!-- Line -->
                                    <Binding Path="MicronsX"/>          <!-- Rectangle, Text -->
                                    <Binding Path="DataContext.ZoomPanManager.Zoom" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Canvas.Top">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource TopEdgeMicronsMultiConverter}">
                                    <Binding Path="StartMicronsY"/>     <!-- Line -->
                                    <Binding Path="EndMicronsY"/>       <!-- Line -->
                                    <Binding Path="MicronsY"/>           <!-- Rectangle -->
                                    <Binding Path="HeightMicrons"/>      <!-- Rectangle -->
                                    <Binding Path="MicronsY"/>           <!-- Text -->
                                    <Binding Path="HeightMicrons"/>      <!-- Text -->
                                    <Binding Path="DataContext.Template.Sheet.HeightMm" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                    <Binding Path="DataContext.ZoomPanManager.Zoom" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ItemsControl.ItemContainerStyle>
            </ItemsControl>

            <!-- Preview линии (обновляется через PreviewLineChangedBehavior) -->
            <Line x:Name="PreviewLineElement"
                  Stroke="Red" StrokeThickness="1.5" StrokeDashArray="4,2"
                  Visibility="Collapsed"/>

            <!-- Preview прямоугольника -->
            <Rectangle x:Name="PreviewRectangleElement"
                       Stroke="Red" Fill="Transparent" StrokeThickness="1.5" StrokeDashArray="4,2"
                       Visibility="Collapsed"/>

            <!-- Preview текста -->
            <TextBlock x:Name="PreviewTextElement"
                       Foreground="Red" FontStyle="Italic"
                       Visibility="Collapsed"/>

            <!-- Preview рамки выделения (Selection Box) -->
            <Rectangle Stroke="Blue" Fill="#200078D4" StrokeThickness="1.5"
                       Visibility="{Binding PreviewManager.SelectionBoxWidth, Converter={StaticResource NonZeroToVisibilityConverter}}">
                <Rectangle.Style>
                    <Style TargetType="Rectangle">
                        <Setter Property="Width">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource MicronsToPixelConverter}">
                                    <Binding Path="PreviewManager.SelectionBoxWidth"/>
                                    <Binding Path="ZoomPanManager.Zoom"/>
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Height">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource MicronsToPixelConverter}">
                                    <Binding Path="PreviewManager.SelectionBoxHeight"/>
                                    <Binding Path="ZoomPanManager.Zoom"/>
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Canvas.Left">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource ModelXToCanvasLeftConverter}">
                                    <Binding Path="PreviewManager.SelectionBoxLeft"/>
                                    <Binding Path="ZoomPanManager.Zoom"/>
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Canvas.Top">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource ModelYToCanvasTopConverter}">
                                    <Binding Path="PreviewManager.SelectionBoxTop"/>
                                    <Binding Path="Template.Sheet.HeightMm"/>
                                    <Binding Path="ZoomPanManager.Zoom"/>
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                        <!-- RTL = зелёная пунктирная, LTR = синяя сплошная -->
                        <Style.Triggers>
                            <DataTrigger Binding="{ Binding PreviewManager.SelectionBoxDirection}" Value="{x:Static coreModels:SelectionDirection.RightToLeft}">
                                <Setter Property="Stroke" Value="#4CAF50"/>
                                <Setter Property="StrokeDashArray" Value="4,2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Rectangle.Style>
            </Rectangle>

            <!-- Inline-редактирование текста -->
            <TextBox x:Name="InlineTextEditor"
                     Text="{Binding InlineEditManager.InlineEditText, UpdateSourceTrigger=PropertyChanged}"
                     Visibility="{Binding InlineEditManager.InlineEditingText, Converter={StaticResource NotNullToVisibility}}"
                     AcceptsReturn="{Binding InlineEditManager.InlineEditingText.TextWrapping}"
                     TextWrapping="{Binding InlineEditManager.InlineEditingText.TextWrapping, Converter={StaticResource BoolToTextWrappingConverter}}"
                     Background="White" BorderBrush="#0078D4" BorderThickness="2"
                     Padding="2" MinWidth="100" MinHeight="24"
                     FontFamily="{Binding InlineEditManager.InlineEditingText.FontName, Converter={StaticResource FontNameToFamilyConverter}}">
                <TextBox.LayoutTransform>
                    <RotateTransform>
                        <RotateTransform.Angle>
                            <Binding Path="InlineEditManager.InlineEditingText.RotationAngle"/>
                        </RotateTransform.Angle>
                    </RotateTransform>
                </TextBox.LayoutTransform>
                <TextBox.FontSize>
                    <MultiBinding Converter="{StaticResource MicronsToPixelConverter}">
                        <Binding Path="InlineEditManager.InlineEditingText.FontSizeMicrons"/>
                        <Binding Path="ZoomPanManager.Zoom"/>
                    </MultiBinding>
                </TextBox.FontSize>
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Canvas.Left">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource ModelXToCanvasLeftConverter}">
                                    <Binding Path="InlineEditManager.InlineEditingText.MicronsX"/>
                                    <Binding Path="ZoomPanManager.Zoom"/>
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Canvas.Top">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource ModelYToCanvasTopConverter}">
                                    <Binding Path="InlineEditManager.InlineEditingText.BottomMicronsY"/>
                                    <Binding Path="Template.Sheet.HeightMm"/>
                                    <Binding Path="ZoomPanManager.Zoom"/>
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding InlineEditManager.InlineEditingText, Converter={StaticResource IsNull}}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Modifiers="Control" Command="{Binding CommitInlineEditingCommand}"/>
                    <KeyBinding Key="Escape" Command="{Binding CancelInlineEditingCommand}"/>
                </TextBox.InputBindings>
            </TextBox>

            <!-- Маркеры выделения (для всех выделенных объектов) -->
            <ItemsControl ItemsSource="{Binding SelectionManager.SelectedObjects}"
                          Visibility="{Binding SelectionManager.ShowSelectionMarkers, Converter={StaticResource BoolToVisibility}}"
                          IsHitTestVisible="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.Resources>
                    <!-- Общий стиль для маркера-круга (линия) -->
                    <Style x:Key="CircleMarker" TargetType="Ellipse">
                        <Setter Property="Width" Value="6"/>
                        <Setter Property="Height" Value="6"/>
                        <Setter Property="Fill" Value="White"/>
                        <Setter Property="Stroke" Value="#0078D4"/>
                        <Setter Property="StrokeThickness" Value="1"/>
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <TranslateTransform X="-3" Y="-3"/>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <!-- Общий стиль для маркера-квадрата (прямоугольник, текст) -->
                    <Style x:Key="SquareMarker" TargetType="Rectangle">
                        <Setter Property="Width" Value="6"/>
                        <Setter Property="Height" Value="6"/>
                        <Setter Property="Fill" Value="White"/>
                        <Setter Property="Stroke" Value="#0078D4"/>
                        <Setter Property="StrokeThickness" Value="1"/>
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <TranslateTransform X="-3" Y="-3"/>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <!-- Line: 2 круга (начало и конец) -->
                    <DataTemplate DataType="{x:Type models:Line}">
                        <Canvas IsHitTestVisible="False">
                            <Ellipse Style="{StaticResource CircleMarker}"
                                     behaviors:MarkerPosition.XPropertyPath="StartMicronsX"
                                     behaviors:MarkerPosition.YPropertyPath="StartMicronsY"/>
                            <Ellipse Style="{StaticResource CircleMarker}"
                                     behaviors:MarkerPosition.XPropertyPath="EndMicronsX"
                                     behaviors:MarkerPosition.YPropertyPath="EndMicronsY"/>
                        </Canvas>
                    </DataTemplate>

                    <!-- Rectangle: 8 квадратов (4 угла + 4 середины) -->
                    <DataTemplate DataType="{x:Type models:Rectangle}">
                        <Canvas IsHitTestVisible="False">
                            <Rectangle Style="{StaticResource SquareMarker}"
                                      behaviors:MarkerPosition.XPropertyPath="MicronsX"
                                      behaviors:MarkerPosition.YPropertyPath="BottomMicronsY"/>
                            <Rectangle Style="{StaticResource SquareMarker}"
                                      behaviors:MarkerPosition.XPropertyPath="RightMicronsX"
                                      behaviors:MarkerPosition.YPropertyPath="BottomMicronsY"/>
                            <Rectangle Style="{StaticResource SquareMarker}"
                                      behaviors:MarkerPosition.XPropertyPath="MicronsX"
                                      behaviors:MarkerPosition.YPropertyPath="MicronsY"/>
                            <Rectangle Style="{StaticResource SquareMarker}"
                                      behaviors:MarkerPosition.XPropertyPath="RightMicronsX"
                                      behaviors:MarkerPosition.YPropertyPath="MicronsY"/>
                            <Rectangle Style="{StaticResource SquareMarker}"
                                      behaviors:MarkerPosition.XPropertyPath="CenterMicronsX"
                                      behaviors:MarkerPosition.YPropertyPath="BottomMicronsY"/>
                            <Rectangle Style="{StaticResource SquareMarker}"
                                      behaviors:MarkerPosition.XPropertyPath="CenterMicronsX"
                                      behaviors:MarkerPosition.YPropertyPath="MicronsY"/>
                            <Rectangle Style="{StaticResource SquareMarker}"
                                      behaviors:MarkerPosition.XPropertyPath="MicronsX"
                                      behaviors:MarkerPosition.YPropertyPath="CenterMicronsY"/>
                            <Rectangle Style="{StaticResource SquareMarker}"
                                      behaviors:MarkerPosition.XPropertyPath="RightMicronsX"
                                      behaviors:MarkerPosition.YPropertyPath="CenterMicronsY"/>
                        </Canvas>
                    </DataTemplate>

                    <!-- Text: 4 квадрата (повёрнутые углы) -->
                    <DataTemplate DataType="{x:Type models:Text}">
                        <Canvas IsHitTestVisible="False">
                            <Rectangle Style="{StaticResource SquareMarker}"
                                      behaviors:MarkerPosition.XPropertyPath="RotatedCorner0X"
                                      behaviors:MarkerPosition.YPropertyPath="RotatedCorner0Y"/>
                            <Rectangle Style="{StaticResource SquareMarker}"
                                      behaviors:MarkerPosition.XPropertyPath="RotatedCorner1X"
                                      behaviors:MarkerPosition.YPropertyPath="RotatedCorner1Y"/>
                            <Rectangle Style="{StaticResource SquareMarker}"
                                      behaviors:MarkerPosition.XPropertyPath="RotatedCorner2X"
                                      behaviors:MarkerPosition.YPropertyPath="RotatedCorner2Y"/>
                            <Rectangle Style="{StaticResource SquareMarker}"
                                      behaviors:MarkerPosition.XPropertyPath="RotatedCorner3X"
                                      behaviors:MarkerPosition.YPropertyPath="RotatedCorner3Y"/>
                        </Canvas>
                    </DataTemplate>

                </ItemsControl.Resources>
            </ItemsControl>

        </Canvas>

                <!-- Узлы сетки поверх Canvas — синхронный pan через RenderTransform -->
                <local:GridNodesLayer x:Name="GridNodesLayer"
                                      Zoom="{Binding ZoomPanManager.Zoom}"
                                      SheetHeightMm="{Binding Template.Sheet.HeightMm}">
                    <local:GridNodesLayer.RenderTransform>
                        <TranslateTransform X="{Binding ZoomPanManager.CanvasOffsetX}" Y="{Binding ZoomPanManager.CanvasOffsetY}"/>
                    </local:GridNodesLayer.RenderTransform>
                </local:GridNodesLayer>
        </Grid>
        </Border>

        <!-- Vertical ScrollBar -->
        <ScrollBar x:Name="VerticalScrollBar" Grid.Row="0" Grid.Column="1" Orientation="Vertical"
                   Style="{StaticResource WorkspaceScrollBar}"
                   Minimum="0"
                   Maximum="{ Binding ZoomPanManager.ScrollYRange}"
                   Value="{ Binding ZoomPanManager.ScrollYValue, Mode=OneWay}"
                   ViewportSize="{ Binding ZoomPanManager.ViewportHeightPixels}"
                   SmallChange="10"
                   LargeChange="100"
                   Visibility="{Binding ZoomPanManager.ScrollYRange, Converter={StaticResource NonZeroToVisibilityConverter}}"/>

        <!-- Horizontal ScrollBar -->
        <ScrollBar x:Name="HorizontalScrollBar" Grid.Row="1" Grid.Column="0" Orientation="Horizontal"
                   Style="{StaticResource WorkspaceScrollBar}"
                   Minimum="0"
                   Maximum="{ Binding ZoomPanManager.ScrollXRange}"
                   Value="{ Binding ZoomPanManager.ScrollXValue, Mode=OneWay}"
                   ViewportSize="{ Binding ZoomPanManager.ViewportWidthPixels}"
                   SmallChange="10"
                   LargeChange="100"
                   Visibility="{Binding ZoomPanManager.ScrollXRange, Converter={StaticResource NonZeroToVisibilityConverter}}"/>

        <!-- Corner -->
        <Rectangle Grid.Row="1" Grid.Column="1" Fill="#E0E0E0"/>
    </Grid>
</UserControl>
