<Window x:Class="DotElectric.TemplateEditor.Views.CustomSheetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Width="400" Height="260"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        TextElement.Foreground="{DynamicResource TextPrimaryBrush}"
        SizeToContent="Height"
        FocusManager.FocusedElement="{Binding ElementName=WidthTextBox}">

    <Window.Resources>
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Описание -->
        <TextBlock Grid.Row="0"
                   Text="{Binding Description}"
                   FontSize="14" Margin="0,0,0,16"
                   TextWrapping="Wrap"/>

        <!-- Ширина -->
        <Grid Grid.Row="1" Margin="0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Ширина (мм):" VerticalAlignment="Center" FontSize="13"/>
            <TextBox x:Name="WidthTextBox" Grid.Column="1"
                     Text="{Binding WidthMm, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="13" Padding="4,2"
                     VerticalContentAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="мм" VerticalAlignment="Center" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,0,0,0"/>
        </Grid>

        <!-- Высота -->
        <Grid Grid.Row="2" Margin="0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Высота (мм):" VerticalAlignment="Center" FontSize="13"/>
            <TextBox x:Name="HeightTextBox" Grid.Column="1"
                     Text="{Binding HeightMm, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="13" Padding="4,2"
                     VerticalContentAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="мм" VerticalAlignment="Center" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,0,0,0"/>
        </Grid>

        <!-- Быстрый выбор -->
        <WrapPanel Grid.Row="3" Margin="0,12,0,4" Orientation="Horizontal">
            <TextBlock Text="Стандартные: " FontSize="12" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,6,0"/>
            <Button Content="A4" FontSize="11" Padding="8,3" Margin="2"
                    Command="{Binding SetQuickFormatCommand}" CommandParameter="A4"/>
            <Button Content="A3" FontSize="11" Padding="8,3" Margin="2"
                    Command="{Binding SetQuickFormatCommand}" CommandParameter="A3"/>
            <Button Content="A2" FontSize="11" Padding="8,3" Margin="2"
                    Command="{Binding SetQuickFormatCommand}" CommandParameter="A2"/>
            <Button Content="A1" FontSize="11" Padding="8,3" Margin="2"
                    Command="{Binding SetQuickFormatCommand}" CommandParameter="A1"/>
            <Button Content="A0" FontSize="11" Padding="8,3" Margin="2"
                    Command="{Binding SetQuickFormatCommand}" CommandParameter="A0"/>
        </WrapPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="ОК" Style="{StaticResource DialogButtonStyle}"
                    Command="{Binding ConfirmCommand}"
                    IsDefault="True"
                    IsEnabled="{Binding CanConfirm}"/>
            <Button Content="Отмена" Style="{StaticResource DialogButtonStyle}"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
